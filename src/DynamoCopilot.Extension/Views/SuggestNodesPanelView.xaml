<UserControl
    x:Class="DynamoCopilot.Extension.Views.SuggestNodesPanelView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:DynamoCopilot.Extension.ViewModels"
    xmlns:conv="clr-namespace:DynamoCopilot.Extension.Converters"
    Background="#1E1E1E"
    Foreground="#D4D4D4"
    FontFamily="Segoe UI"
    FontSize="13"
    MinWidth="280">

    <UserControl.Resources>

        <!-- ── Colours ──────────────────────────────────────────────────── -->
        <SolidColorBrush x:Key="BgBrush"       Color="#1E1E1E"/>
        <SolidColorBrush x:Key="BgInputBrush"  Color="#2D2D2D"/>
        <SolidColorBrush x:Key="BgAssistBrush" Color="#252526"/>
        <SolidColorBrush x:Key="AccentBrush"   Color="#6EC6F5"/>
        <SolidColorBrush x:Key="BorderBrush"   Color="#3A3A3A"/>
        <SolidColorBrush x:Key="TextBrush"     Color="#D4D4D4"/>
        <SolidColorBrush x:Key="MutedBrush"    Color="#8B8B8B"/>
        <SolidColorBrush x:Key="ErrorBrush"    Color="#F48771"/>

        <!-- ── Converters ─────────────────────────────────────────────── -->
        <BooleanToVisibilityConverter          x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>

        <!-- ── Thin scrollbar ────────────────────────────────────────── -->
        <Style x:Key="ThinScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#3A3A3A" CornerRadius="3" Margin="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThinScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter x:Name="PART_ScrollContentPresenter" Grid.Column="0" CanContentScroll="False"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       Grid.Column="1"
                                       Orientation="Vertical"
                                       Style="{StaticResource ThinScrollBar}"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Shared button styles ──────────────────────────────────── -->
        <Style x:Key="FlatBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3A3A3A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#6EC6F5"/>
            <Setter Property="Foreground" Value="#000"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#9CD5F9"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#3A3A3A"/>
                    <Setter Property="Foreground" Value="#6B6B6B"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4A4A4A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DarkInput" TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#6EC6F5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#6EC6F5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#6EC6F5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#6EC6F5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  ROOT — switches between Login panel and Main panel                -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <Grid>

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!--  LOGIN / REGISTER PANEL                                        -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <Grid Visibility="{Binding IsLoggedIn, Converter={StaticResource InvBoolToVis}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="28,32,28,24" VerticalAlignment="Center">

                    <!-- Logo + title -->
                    <Path Data="M21 21l-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z"
                          Fill="#6EC6F5" Width="36" Height="36" Stretch="Uniform"
                          HorizontalAlignment="Center" Margin="0,0,0,10" Opacity="0.9"/>
                    <TextBlock Text="Suggest Nodes"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock FontSize="12" Foreground="{StaticResource MutedBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,28">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Sign in to continue"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRegisterMode}" Value="True">
                                        <Setter Property="Text" Value="Create your account"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- ── LOGIN FORM ── -->
                    <StackPanel Visibility="{Binding IsLoginMode, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Email" FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                        <TextBox x:Name="LoginEmailBox"
                                 Style="{StaticResource DarkInput}"
                                 Text="{Binding LoginEmail, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,12"/>

                        <TextBlock Text="Password" FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                        <PasswordBox x:Name="LoginPasswordBox"
                                     Style="{StaticResource DarkPasswordBox}"
                                     Margin="0,0,0,20"/>

                        <Button Content="Sign In"
                                Style="{StaticResource PrimaryBtn}"
                                Padding="0,10" FontSize="13"
                                IsEnabled="{Binding IsAuthIdle}"
                                Click="OnLoginClick"
                                Margin="0,0,0,16"/>

                        <TextBlock Text="Signing in…"
                                   FontSize="12" Foreground="{StaticResource MutedBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"
                                   Visibility="{Binding IsAuthBusy, Converter={StaticResource BoolToVis}}"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="Don't have an account? " FontSize="12" Foreground="{StaticResource MutedBrush}"/>
                            <TextBlock FontSize="12" Foreground="{StaticResource AccentBrush}"
                                       Cursor="Hand" MouseLeftButtonUp="OnSwitchToRegister">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Create account"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="TextDecorations" Value="Underline"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <!-- ── REGISTER FORM ── -->
                    <StackPanel Visibility="{Binding IsRegisterMode, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Email" FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                        <TextBox x:Name="RegisterEmailBox"
                                 Style="{StaticResource DarkInput}"
                                 Text="{Binding RegisterEmail, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,12"/>

                        <TextBlock Text="Password" FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                        <PasswordBox x:Name="RegisterPasswordBox"
                                     Style="{StaticResource DarkPasswordBox}"
                                     Margin="0,0,0,12"/>

                        <TextBlock Text="Confirm Password" FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                        <PasswordBox x:Name="RegisterConfirmPasswordBox"
                                     Style="{StaticResource DarkPasswordBox}"
                                     Margin="0,0,0,20"/>

                        <Button Content="Create Account"
                                Style="{StaticResource PrimaryBtn}"
                                Padding="0,10" FontSize="13"
                                IsEnabled="{Binding IsAuthIdle}"
                                Click="OnRegisterClick"
                                Margin="0,0,0,16"/>

                        <TextBlock Text="Creating account…"
                                   FontSize="12" Foreground="{StaticResource MutedBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"
                                   Visibility="{Binding IsAuthBusy, Converter={StaticResource BoolToVis}}"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="Already have an account? " FontSize="12" Foreground="{StaticResource MutedBrush}"/>
                            <TextBlock FontSize="12" Foreground="{StaticResource AccentBrush}"
                                       Cursor="Hand" MouseLeftButtonUp="OnSwitchToLogin">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Sign in"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="TextDecorations" Value="Underline"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <!-- ── Error message (shared) ── -->
                    <Border Background="#3D1515" BorderBrush="#F48771" BorderThickness="1"
                            CornerRadius="5" Padding="10,8" Margin="0,16,0,0"
                            Visibility="{Binding HasAuthError, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding AuthError}"
                                   Foreground="{StaticResource ErrorBrush}"
                                   FontSize="12" TextWrapping="Wrap"/>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!--  MAIN PANEL (logged in)                                        -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <Grid Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Row 0: Header -->
                <RowDefinition Height="Auto"/>  <!-- Row 1: User info dropdown -->
                <RowDefinition Height="Auto"/>  <!-- Row 2: Search input -->
                <RowDefinition Height="*"/>     <!-- Row 3: Results -->
                <RowDefinition Height="Auto"/>  <!-- Row 4: Status bar -->
            </Grid.RowDefinitions>

            <!-- ── Header ─────────────────────────────────────────── -->
            <Border Grid.Row="0"
                    Background="#252526"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="12,8">
                <Grid>
                    <!-- Left: logo + title -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Path Data="M21 21l-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z"
                              Fill="#6EC6F5" Width="14" Height="14" Stretch="Uniform" Margin="0,0,7,0"/>
                        <TextBlock Text="Suggest Nodes"
                                   Foreground="{StaticResource TextBrush}"
                                   FontWeight="SemiBold" FontSize="13"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Right: user icon -->
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                            ToolTip="Account info"
                            Click="OnUserInfoClick"
                            Style="{StaticResource FlatBtn}"
                            Padding="5">
                        <Path Data="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6m2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0m4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4m-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.029 10 8 10s-3.516.68-4.168 1.332c-.678.678-.83 1.418-.832 1.664z"
                              Width="16" Height="16" Stretch="Uniform">
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="Fill" Value="{StaticResource MutedBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ShowUserPanel}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Button>
                </Grid>
            </Border>

            <!-- ── User info dropdown (Row 1) ─────────────────────── -->
            <Border Grid.Row="1"
                    Background="#252526"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="14,14"
                    Visibility="{Binding ShowUserPanel, Converter={StaticResource BoolToVis}}">
                <StackPanel>

                    <!-- Email row -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Path Data="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6m2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0m4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4m-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.029 10 8 10s-3.516.68-4.168 1.332c-.678.678-.83 1.418-.832 1.664z"
                              Fill="{StaticResource MutedBrush}" Width="13" Height="13"
                              Stretch="Uniform" Margin="0,0,7,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding UserEmail}"
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Licence status -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Ellipse Width="8" Height="8" Margin="0,0,7,0" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#73C991"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLicenceActive}" Value="False">
                                            <Setter Property="Fill" Value="{StaticResource ErrorBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock FontSize="11" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text"       Value="Active licence"/>
                                    <Setter Property="Foreground" Value="#73C991"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLicenceActive}" Value="False">
                                            <Setter Property="Text"       Value="No active licence"/>
                                            <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <!-- Expiry row -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Expires on:"
                                   FontSize="11" Foreground="{StaticResource MutedBrush}"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding LicenseExpiryDisplay}"
                                   FontSize="11" FontWeight="SemiBold"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLicenseExpired}" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <!-- Tokens today -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <TextBlock Text="Tokens today:"
                                   FontSize="11" Foreground="{StaticResource MutedBrush}"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding TokensDisplay}"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Sign out -->
                    <Button Content="Sign Out"
                            Style="{StaticResource SecondaryBtn}"
                            Padding="0,7" FontSize="12"
                            Click="OnSignOutClick"/>
                </StackPanel>
            </Border>

            <!-- ── No-licence notice (Row 2-4, shown when IsLicenceActive=false) ── -->
            <Border Grid.Row="2" Grid.RowSpan="3"
                    Visibility="{Binding IsLicenceActive, Converter={StaticResource InvBoolToVis}}"
                    VerticalAlignment="Center" Margin="28,0">
                <StackPanel HorizontalAlignment="Center">
                    <Path Data="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16"
                          Fill="{StaticResource ErrorBrush}" Width="32" Height="32"
                          Stretch="Uniform" HorizontalAlignment="Center" Margin="0,0,0,16" Opacity="0.8"/>
                    <TextBlock Text="{Binding LicenseMessage}"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="13" TextWrapping="Wrap" TextAlignment="Center"
                               LineHeight="20"/>
                </StackPanel>
            </Border>

            <!-- ── Search input (Row 2) ────────────────────────────── -->
            <Border Grid.Row="2"
                    Visibility="{Binding IsLicenceActive, Converter={StaticResource BoolToVis}}"
                    Background="#252526"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="8,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             x:Name="NodeQueryBox"
                             Text="{Binding NodeQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource DarkInput}"
                             AcceptsReturn="False"
                             MaxLines="2"
                             PreviewKeyDown="OnNodeQueryKeyDown"
                             Margin="0,0,6,0"/>

                    <Button Grid.Column="1"
                            Content="Search"
                            Width="60" Height="34"
                            Style="{StaticResource PrimaryBtn}"
                            IsEnabled="{Binding CanSearchNodes}"
                            Click="OnNodeSearchClick"/>
                </Grid>
            </Border>

            <!-- ── Results scroll area (Row 3) ────────────────────── -->
            <ScrollViewer Grid.Row="3"
                          Visibility="{Binding IsLicenceActive, Converter={StaticResource BoolToVis}}"
                          Style="{StaticResource ThinScrollViewer}"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="{StaticResource BgBrush}"
                          Padding="0,4">
                <StackPanel>

                    <!-- Loading indicator -->
                    <TextBlock Text="Searching…"
                               FontSize="12" Foreground="{StaticResource MutedBrush}"
                               HorizontalAlignment="Center" Margin="0,24,0,0"
                               Visibility="{Binding IsSearchingNodes, Converter={StaticResource BoolToVis}}"/>

                    <!-- Empty state hint -->
                    <StackPanel HorizontalAlignment="Center"
                                Margin="16,32,16,0"
                                Visibility="{Binding ShowNodeHint, Converter={StaticResource BoolToVis}}">
                        <Path Data="M21 21l-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z"
                              Fill="{StaticResource AccentBrush}"
                              Width="36" Height="36" Stretch="Uniform"
                              HorizontalAlignment="Center" Margin="0,0,0,12" Opacity="0.6"/>
                        <TextBlock Text="Suggest Nodes"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,6"/>
                        <TextBlock FontSize="12" Foreground="{StaticResource MutedBrush}"
                                   TextWrapping="Wrap" TextAlignment="Center" MaxWidth="230"
                                   Text="Describe what you need — find the best Dynamo nodes from 78 000+ indexed packages."/>
                    </StackPanel>

                    <!-- Node suggestion cards -->
                    <ItemsControl ItemsSource="{Binding NodeSuggestions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:NodeSuggestionCardViewModel}">
                                <Border Margin="6,4"
                                        CornerRadius="8"
                                        Background="{StaticResource BgAssistBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1">
                                    <StackPanel>

                                        <!-- Card header -->
                                        <Grid Margin="10,8,10,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="SemiBold" FontSize="13"
                                                           Foreground="{StaticResource TextBrush}"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding PackageName}"
                                                           FontSize="11"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           Margin="0,1,0,0"/>
                                            </StackPanel>
                                            <!-- Score badge -->
                                            <Border Grid.Column="1"
                                                    Background="#1A2A3A" CornerRadius="10"
                                                    Padding="7,2" VerticalAlignment="Top" Margin="8,0,0,0">
                                                <TextBlock Text="{Binding ScoreText}"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           FontSize="10" FontFamily="Consolas"/>
                                            </Border>
                                        </Grid>

                                        <!-- AI reason -->
                                        <Border Margin="10,0,10,6"
                                                CornerRadius="5"
                                                Background="#0F2030"
                                                BorderBrush="#1E3A50"
                                                BorderThickness="1"
                                                Padding="8,6"
                                                Visibility="{Binding HasReason, Converter={StaticResource BoolToVis}}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="&#x2728; " FontSize="12" VerticalAlignment="Top"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Reason}"
                                                           Foreground="{StaticResource TextBrush}"
                                                           FontSize="12" FontStyle="Italic" TextWrapping="Wrap"/>
                                            </Grid>
                                        </Border>

                                        <!-- Expand / collapse -->
                                        <ToggleButton IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                                      HorizontalAlignment="Left"
                                                      Margin="10,0,10,8"
                                                      FontSize="11" Cursor="Hand"
                                                      Visibility="{Binding HasPorts, Converter={StaticResource BoolToVis}}">
                                            <ToggleButton.Style>
                                                <Style TargetType="ToggleButton">
                                                    <Setter Property="Content"         Value="&#x25B6; Show details"/>
                                                    <Setter Property="Background"      Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="Foreground"      Value="{StaticResource MutedBrush}"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ToggleButton">
                                                                <Border Background="{TemplateBinding Background}" Padding="0,2">
                                                                    <ContentPresenter/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter Property="Content"   Value="&#x25BC; Hide details"/>
                                                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ToggleButton.Style>
                                        </ToggleButton>

                                        <!-- Detail section -->
                                        <StackPanel Margin="10,0,10,10"
                                                    Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="{Binding Description}"
                                                       FontSize="12" Foreground="{StaticResource MutedBrush}"
                                                       TextWrapping="Wrap" Margin="0,0,0,6"
                                                       Visibility="{Binding HasDescription, Converter={StaticResource BoolToVis}}"/>
                                            <Grid Visibility="{Binding HasPorts, Converter={StaticResource BoolToVis}}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="In: "  FontSize="11" Foreground="{StaticResource MutedBrush}" FontFamily="Consolas" Margin="0,0,4,2"/>
                                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding InputPorts}"  FontSize="11" Foreground="{StaticResource TextBrush}" FontFamily="Consolas" TextWrapping="Wrap"/>
                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Out: " FontSize="11" Foreground="{StaticResource MutedBrush}" FontFamily="Consolas" Margin="0,0,4,0"/>
                                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding OutputPorts}" FontSize="11" Foreground="{StaticResource TextBrush}" FontFamily="Consolas" TextWrapping="Wrap"/>
                                            </Grid>
                                        </StackPanel>

                                        <!-- Status text -->
                                        <TextBlock Margin="10,0,10,4"
                                                   Text="{Binding StatusText}"
                                                   FontSize="11" Foreground="#E07070"
                                                   TextWrapping="Wrap"
                                                   Visibility="{Binding HasStatus, Converter={StaticResource BoolToVis}}"/>

                                        <!-- Action buttons -->
                                        <Grid Margin="10,4,10,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Button Grid.Column="0"
                                                    Command="{Binding InsertCommand}"
                                                    Content="Insert"
                                                    Padding="10,4" FontSize="12" Cursor="Hand">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Background"      Value="#1A6E3C"/>
                                                        <Setter Property="Foreground"      Value="#FFFFFF"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsEnabled"   Value="False"><Setter Property="Background" Value="#1E3A2A"/><Setter Property="Foreground" Value="#4A7A5A"/></Trigger>
                                                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#22924F"/></Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>

                                            <Button Grid.Column="2"
                                                    Command="{Binding DownloadCommand}"
                                                    Content="Download"
                                                    Padding="10,4" FontSize="12" Cursor="Hand">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Background"      Value="#1A3A6E"/>
                                                        <Setter Property="Foreground"      Value="#FFFFFF"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsEnabled"   Value="False"><Setter Property="Background" Value="#1A2A3A"/><Setter Property="Foreground" Value="#4A6A8A"/></Trigger>
                                                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#1E4A92"/></Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>

                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>

            <!-- ── Status bar (Row 4) ──────────────────────────────── -->
            <Border Grid.Row="4"
                    Background="#252526"
                    Padding="12,4"
                    Visibility="{Binding HasStatus, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="11"
                           Foreground="{StaticResource MutedBrush}"
                           TextTrimming="CharacterEllipsis"/>
            </Border>

        </Grid>
        <!-- end main panel -->

    </Grid>
</UserControl>
