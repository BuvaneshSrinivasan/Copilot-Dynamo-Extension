<UserControl
    x:Class="DynamoCopilot.Extension.Views.CopilotPanelView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:DynamoCopilot.Extension.ViewModels"
    xmlns:conv="clr-namespace:DynamoCopilot.Extension.Converters"
    Background="#1E1E1E"
    Foreground="#D4D4D4"
    FontFamily="Segoe UI"
    FontSize="13"
    MinWidth="280">

    <UserControl.Resources>

        <!-- ── Colours ──────────────────────────────────────────────────── -->
        <SolidColorBrush x:Key="BgBrush"       Color="#1E1E1E"/>
        <SolidColorBrush x:Key="BgInputBrush"  Color="#2D2D2D"/>
        <SolidColorBrush x:Key="BgUserBrush"   Color="#2A3A52"/>
        <SolidColorBrush x:Key="BgAssistBrush" Color="#252526"/>
        <SolidColorBrush x:Key="BgCodeBrush"   Color="#1A1A1A"/>
        <SolidColorBrush x:Key="AccentBrush"   Color="#6EC6F5"/>
        <SolidColorBrush x:Key="BorderBrush"   Color="#3A3A3A"/>
        <SolidColorBrush x:Key="TextBrush"     Color="#D4D4D4"/>
        <SolidColorBrush x:Key="MutedBrush"    Color="#8B8B8B"/>
        <SolidColorBrush x:Key="ErrorBrush"    Color="#F48771"/>

        <!-- ── Converters ─────────────────────────────────────────────── -->
        <BooleanToVisibilityConverter         x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>

        <!-- ── Thin scrollbar ────────────────────────────────────────── -->
        <Style x:Key="ThinScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#3A3A3A" CornerRadius="3" Margin="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThinScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                                    Grid.Column="0" CanContentScroll="True"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       Grid.Column="1"
                                       Orientation="Vertical"
                                       Style="{StaticResource ThinScrollBar}"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Thin horizontal scroll bar ───────────────────────────── -->
        <Style x:Key="ThinScrollBarH" TargetType="ScrollBar">
            <Setter Property="Height" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageLeftCommand" Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#3A3A3A" CornerRadius="3" Margin="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageRightCommand" Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Code block scroll viewer (horizontal only, thin bar) ─── -->
        <Style x:Key="CodeScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                                    Grid.Row="0"/>
                            <ScrollBar x:Name="PART_HorizontalScrollBar"
                                       Grid.Row="1"
                                       Orientation="Horizontal"
                                       Style="{StaticResource ThinScrollBarH}"
                                       Value="{TemplateBinding HorizontalOffset}"
                                       Maximum="{TemplateBinding ScrollableWidth}"
                                       ViewportSize="{TemplateBinding ViewportWidth}"
                                       Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Shared button style (flat, dark) ─────────────────────── -->
        <Style x:Key="FlatBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3A3A3A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Primary action button (blue) ─────────────────────────── -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#6EC6F5"/>
            <Setter Property="Foreground" Value="#000"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#9CD5F9"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#3A3A3A"/>
                    <Setter Property="Foreground" Value="#6B6B6B"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Secondary button (dark grey) ─────────────────────────── -->
        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4A4A4A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Dark text input ───────────────────────────────────────── -->
        <Style x:Key="DarkInput" TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#6EC6F5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#6EC6F5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Dark password input ───────────────────────────────────── -->
        <Style x:Key="DarkPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#6EC6F5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#6EC6F5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Chat message templates ────────────────────────────────── -->
        <DataTemplate x:Key="UserMessageTemplate" DataType="{x:Type vm:ChatMessageViewModel}">
            <Grid Margin="8,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="You"
                           FontSize="10" Foreground="{StaticResource MutedBrush}"
                           FontWeight="SemiBold" Margin="0,0,0,3"
                           HorizontalAlignment="Right"/>
                <Border Grid.Row="1"
                        Background="{StaticResource BgUserBrush}"
                        CornerRadius="8,8,2,8"
                        Padding="10,8"
                        HorizontalAlignment="Right"
                        MaxWidth="320">
                    <TextBox Text="{Binding Content}"
                             Foreground="{StaticResource TextBrush}"
                             Background="Transparent"
                             BorderThickness="0"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             FontSize="13"
                             Padding="0"
                             Cursor="IBeam"/>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="AssistantMessageTemplate" DataType="{x:Type vm:ChatMessageViewModel}">
            <Grid Margin="8,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Dynamo Co-pilot"
                           FontSize="10" Foreground="{StaticResource AccentBrush}"
                           FontWeight="SemiBold" Margin="0,0,0,3"
                           HorizontalAlignment="Left"/>
                <Border Grid.Row="1"
                        Background="{StaticResource BgAssistBrush}"
                        CornerRadius="8,8,8,2"
                        Padding="10,8"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,8,0">
                    <StackPanel>
                        <TextBox Text="{Binding Content}"
                                 Foreground="{StaticResource TextBrush}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 FontSize="13"
                                 Padding="0"
                                 Cursor="IBeam"/>
                        <!-- Streaming dots -->
                        <StackPanel Orientation="Horizontal"
                                    Visibility="{Binding IsStreaming, Converter={StaticResource BoolToVis}}">
                            <Ellipse Width="5" Height="5" Fill="{StaticResource AccentBrush}" Margin="2,4,2,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Style.Triggers>
                                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="1" To="0.2" Duration="0:0:0.6" AutoReverse="True"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <Ellipse Width="5" Height="5" Fill="{StaticResource AccentBrush}" Margin="2,4,2,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Style.Triggers>
                                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.2">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="1" To="0.2" Duration="0:0:0.6" AutoReverse="True"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <Ellipse Width="5" Height="5" Fill="{StaticResource AccentBrush}" Margin="2,4,2,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Style.Triggers>
                                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.4">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="1" To="0.2" Duration="0:0:0.6" AutoReverse="True"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <!-- Code block -->
                <Border Grid.Row="2"
                        Background="{StaticResource BgCodeBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Margin="0,6,8,0"
                        Visibility="{Binding HasCode, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <Border Background="#2A2A2A" CornerRadius="6,6,0,0" Padding="10,5">
                            <Grid>
                                <TextBlock Text="python" Foreground="{StaticResource MutedBrush}"
                                           FontSize="11" FontFamily="Consolas"
                                           VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="Copy" FontSize="11" Padding="8,3" Margin="0,0,4,0"
                                            Click="OnCopyCodeClick" Tag="{Binding CodeSnippet}" Cursor="Hand">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="#3A3A3A"/>
                                                <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#4A4A4A"/>
                                                        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="Insert ↗" FontSize="11" FontWeight="SemiBold"
                                            Padding="8,3" Click="OnInsertCodeClick"
                                            Tag="{Binding CodeSnippet}" Cursor="Hand">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="#6EC6F5"/>
                                                <Setter Property="Foreground" Value="#000000"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#9CD5F9"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <ScrollViewer Style="{StaticResource CodeScrollViewer}"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled"
                                      Padding="10,8">
                            <TextBox Text="{Binding CodeSnippet}"
                                     FontFamily="Cascadia Code, Consolas, Courier New"
                                     FontSize="12"
                                     Foreground="#CE9178"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     IsReadOnly="True"
                                     TextWrapping="NoWrap"
                                     Padding="0"
                                     Cursor="IBeam"/>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="MessageTemplate" DataType="{x:Type vm:ChatMessageViewModel}">
            <ContentControl>
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Setter Property="ContentTemplate" Value="{StaticResource AssistantMessageTemplate}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsUser}" Value="True">
                                <Setter Property="ContentTemplate" Value="{StaticResource UserMessageTemplate}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
                <ContentControl.Content>
                    <Binding/>
                </ContentControl.Content>
            </ContentControl>
        </DataTemplate>

    </UserControl.Resources>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  ROOT — switches between Login panel and Chat panel                -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <Grid>

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!--  LOGIN / REGISTER PANEL                                        -->
        <!--  Visible when IsLoggedIn = false                               -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <Grid Visibility="{Binding IsLoggedIn, Converter={StaticResource InvBoolToVis}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="28,32,28,24" VerticalAlignment="Center">

                    <!-- Logo + title -->
                    <Path Data="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z"
                          Fill="#6EC6F5" Width="36" Height="36" Stretch="Uniform"
                          HorizontalAlignment="Center" Margin="0,0,0,10" Opacity="0.9"/>
                    <TextBlock Text="Dynamo Co-pilot"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock FontSize="12" Foreground="{StaticResource MutedBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,28">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Sign in to continue"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRegisterMode}" Value="True">
                                        <Setter Property="Text" Value="Create your account"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- ── LOGIN FORM ── -->
                    <StackPanel Visibility="{Binding IsLoginMode, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Email" FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                        <TextBox x:Name="LoginEmailBox"
                                 Style="{StaticResource DarkInput}"
                                 Text="{Binding LoginEmail, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,12"/>

                        <TextBlock Text="Password" FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                        <PasswordBox x:Name="LoginPasswordBox"
                                     Style="{StaticResource DarkPasswordBox}"
                                     Margin="0,0,0,20"/>

                        <Button x:Name="LoginBtn"
                                Content="Sign In"
                                Style="{StaticResource PrimaryBtn}"
                                Padding="0,10"
                                FontSize="13"
                                IsEnabled="{Binding IsAuthIdle}"
                                Click="OnLoginClick"
                                Margin="0,0,0,16"/>

                        <!-- Busy indicator -->
                        <TextBlock Text="Signing in…"
                                   FontSize="12" Foreground="{StaticResource MutedBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"
                                   Visibility="{Binding IsAuthBusy, Converter={StaticResource BoolToVis}}"/>

                        <!-- Toggle to Register -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="Don't have an account? "
                                       FontSize="12" Foreground="{StaticResource MutedBrush}"/>
                            <TextBlock FontSize="12" Foreground="{StaticResource AccentBrush}"
                                       Cursor="Hand" x:Name="SwitchToRegisterLink"
                                       MouseLeftButtonUp="OnSwitchToRegister">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Create account"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="TextDecorations" Value="Underline"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <!-- ── REGISTER FORM ── -->
                    <StackPanel Visibility="{Binding IsRegisterMode, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Email" FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                        <TextBox x:Name="RegisterEmailBox"
                                 Style="{StaticResource DarkInput}"
                                 Text="{Binding RegisterEmail, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,12"/>

                        <TextBlock Text="Password" FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                        <PasswordBox x:Name="RegisterPasswordBox"
                                     Style="{StaticResource DarkPasswordBox}"
                                     Margin="0,0,0,12"/>

                        <TextBlock Text="Confirm Password" FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                        <PasswordBox x:Name="RegisterConfirmPasswordBox"
                                     Style="{StaticResource DarkPasswordBox}"
                                     Margin="0,0,0,20"/>

                        <Button x:Name="RegisterBtn"
                                Content="Create Account"
                                Style="{StaticResource PrimaryBtn}"
                                Padding="0,10"
                                FontSize="13"
                                IsEnabled="{Binding IsAuthIdle}"
                                Click="OnRegisterClick"
                                Margin="0,0,0,16"/>

                        <!-- Busy indicator -->
                        <TextBlock Text="Creating account…"
                                   FontSize="12" Foreground="{StaticResource MutedBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"
                                   Visibility="{Binding IsAuthBusy, Converter={StaticResource BoolToVis}}"/>

                        <!-- Toggle to Login -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="Already have an account? "
                                       FontSize="12" Foreground="{StaticResource MutedBrush}"/>
                            <TextBlock FontSize="12" Foreground="{StaticResource AccentBrush}"
                                       Cursor="Hand" x:Name="SwitchToLoginLink"
                                       MouseLeftButtonUp="OnSwitchToLogin">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Sign in"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="TextDecorations" Value="Underline"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <!-- ── Error message (shared) ── -->
                    <Border Background="#3D1515" BorderBrush="#F48771" BorderThickness="1"
                            CornerRadius="5" Padding="10,8" Margin="0,16,0,0"
                            Visibility="{Binding HasAuthError, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding AuthError}"
                                   Foreground="{StaticResource ErrorBrush}"
                                   FontSize="12" TextWrapping="Wrap"/>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!--  CHAT PANEL                                                     -->
        <!--  Visible when IsLoggedIn = true                                 -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <Grid Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- Header -->
                <RowDefinition Height="Auto"/>   <!-- User info dropdown -->
                <RowDefinition Height="*"/>      <!-- Chat area -->
                <RowDefinition Height="Auto"/>   <!-- Status bar -->
                <RowDefinition Height="Auto"/>   <!-- Input row -->
            </Grid.RowDefinitions>

            <!-- ── Header ─────────────────────────────────────────── -->
            <Border Grid.Row="0"
                    Background="#252526"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="12,8">
                <Grid>
                    <!-- Left: logo + title -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Path Data="M8,1 L9.2,5.5 L13.5,5.5 L10,8.5 L11.2,13 L8,10.5 L4.8,13 L6,8.5 L2.5,5.5 L6.8,5.5 Z"
                              Fill="#6EC6F5" Width="14" Height="14" Stretch="Uniform" Margin="0,0,7,0"/>
                        <TextBlock Text="Dynamo Co-pilot"
                                   Foreground="{StaticResource TextBrush}"
                                   FontWeight="SemiBold" FontSize="13"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Right: action buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">

                        <!-- Clear conversation -->
                        <Button ToolTip="Clear conversation"
                                Click="OnClearClick"
                                Style="{StaticResource FlatBtn}"
                                Padding="5" Margin="0,0,4,0">
                            <Path Data="M6.5 1h3a.5.5 0 0 1 .5.5v1H6v-1a.5.5 0 0 1 .5-.5M11 2.5v-1A1.5 1.5 0 0 0 9.5 0h-3A1.5 1.5 0 0 0 5 1.5v1H1.5a.5.5 0 0 0 0 1H2v9a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2v-9h.5a.5.5 0 0 0 0-1H11Z"
                                  Fill="{StaticResource MutedBrush}" Width="14" Height="14" Stretch="Uniform"/>
                        </Button>

                        <!-- User icon — click to toggle user info panel -->
                        <Button x:Name="UserIconBtn"
                                ToolTip="Account &amp; usage"
                                Click="OnUserIconClick"
                                Style="{StaticResource FlatBtn}"
                                Padding="5">
                            <!-- Person icon -->
                            <Path Data="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6m2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0m4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4m-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.029 10 8 10s-3.516.68-4.168 1.332c-.678.678-.83 1.418-.832 1.664z"
                                  Width="16" Height="16" Stretch="Uniform">
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Setter Property="Fill" Value="{StaticResource MutedBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ShowUserInfo}" Value="True">
                                                <Setter Property="Fill" Value="{StaticResource AccentBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Path.Style>
                            </Path>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── User info dropdown (Row 1) ─────────────────────── -->
            <Border Grid.Row="1"
                    Background="#252526"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="14,12"
                    Visibility="{Binding ShowUserInfo, Converter={StaticResource BoolToVis}}">
                <StackPanel>

                    <!-- Email row -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Path Data="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6m2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0m4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4m-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.029 10 8 10s-3.516.68-4.168 1.332c-.678.678-.83 1.418-.832 1.664z"
                              Fill="{StaticResource AccentBrush}" Width="14" Height="14"
                              Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding UserEmail}"
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Divider -->
                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Margin="0,0,0,10"/>

                    <!-- Usage stats -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Tokens today"
                                   FontSize="11" Foreground="{StaticResource MutedBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding TokensDisplay}"
                                   FontSize="11" Foreground="{StaticResource TextBrush}"
                                   FontFamily="Consolas"/>
                    </Grid>

                    <!-- Divider -->
                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Margin="0,0,0,10"/>

                    <!-- Sign out -->
                    <Button Content="Sign Out"
                            Style="{StaticResource SecondaryBtn}"
                            Padding="0,7"
                            FontSize="12"
                            Click="OnSignOutClick"/>
                </StackPanel>
            </Border>

            <!-- ── Chat scroll area (Row 2) ───────────────────────── -->
            <ScrollViewer Grid.Row="2"
                          x:Name="ChatScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Style="{StaticResource ThinScrollViewer}"
                          Background="{StaticResource BgBrush}"
                          Padding="0,4"
                          PreviewMouseWheel="OnChatPreviewMouseWheel">
                <Grid>
                    <!-- Welcome state -->
                    <StackPanel Margin="16,32,16,0"
                                HorizontalAlignment="Center"
                                Visibility="{Binding ShowWelcome, Converter={StaticResource BoolToVis}}">
                        <Path Data="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z"
                              Fill="#6EC6F5" Width="40" Height="40" Stretch="Uniform"
                              HorizontalAlignment="Center" Margin="0,0,0,12" Opacity="0.8"/>
                        <TextBlock Text="Dynamo Co-pilot"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="Ask me to write Dynamo Python Script code using the Revit API."
                                   FontSize="12" Foreground="{StaticResource MutedBrush}"
                                   TextWrapping="Wrap" TextAlignment="Center"
                                   MaxWidth="240" Margin="0,0,0,20"/>
                        <!-- Example prompts -->
                        <StackPanel>
                            <Button Content="Get all wall lengths in view"
                                    Tag="Get all walls in the current view and return their lengths"
                                    Click="OnExampleClick" Margin="0,0,0,6" Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#2D2D2D"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="Padding" Value="10,8"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#333"/>
                                                <Setter Property="BorderBrush" Value="#6EC6F5"/>
                                                <Setter Property="Foreground" Value="#6EC6F5"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="List levels by elevation"
                                    Tag="Get all Revit levels and sort them by elevation"
                                    Click="OnExampleClick" Margin="0,0,0,6" Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#2D2D2D"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="Padding" Value="10,8"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#333"/>
                                                <Setter Property="BorderBrush" Value="#6EC6F5"/>
                                                <Setter Property="Foreground" Value="#6EC6F5"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="Rename sheets with a prefix"
                                    Tag="Rename all sheets by prefixing their number with a custom prefix from IN[0]"
                                    Click="OnExampleClick" Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#2D2D2D"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="Padding" Value="10,8"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#333"/>
                                                <Setter Property="BorderBrush" Value="#6EC6F5"/>
                                                <Setter Property="Foreground" Value="#6EC6F5"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </StackPanel>

                    <!-- Message list -->
                    <ItemsControl ItemsSource="{Binding Messages}"
                                  ItemTemplate="{StaticResource MessageTemplate}"
                                  Visibility="{Binding ShowWelcome, Converter={StaticResource InvBoolToVis}}"/>
                </Grid>
            </ScrollViewer>

            <!-- ── Status bar (Row 3) ──────────────────────────────── -->
            <Border Grid.Row="3"
                    Background="#252526"
                    Padding="12,4"
                    Visibility="{Binding HasStatus, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="11"
                           Foreground="{StaticResource MutedBrush}"
                           TextTrimming="CharacterEllipsis"/>
            </Border>

            <!-- ── Input area (Row 4) ──────────────────────────────── -->
            <Border Grid.Row="4"
                    Background="#252526"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="8,8">
                <StackPanel>

                    <!-- Text input + Send button -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 x:Name="InputBox"
                                 Background="{StaticResource BgInputBrush}"
                                 Foreground="{StaticResource TextBrush}"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 BorderThickness="1"
                                 Padding="10,8"
                                 FontSize="13"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="False"
                                 MaxLines="5"
                                 VerticalScrollBarVisibility="Auto"
                                 CaretBrush="{StaticResource AccentBrush}"
                                 PreviewKeyDown="OnInputKeyDown"
                                 Margin="0,0,6,0">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="6">
                                                    <ScrollViewer x:Name="PART_ContentHost"
                                                                  Margin="{TemplateBinding Padding}"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsFocused" Value="True">
                                                        <Setter Property="BorderBrush" Value="#6EC6F5"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <!-- Send / Stop button -->
                        <Button Grid.Column="1"
                                Width="36" Height="36"
                                Click="OnSendClick"
                                Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#6EC6F5"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="6">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#9CD5F9"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding IsStreaming}" Value="True">
                                            <Setter Property="Background" Value="#3A3A3A"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <!-- Send arrow / Stop square -->
                            <Path>
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <!-- Send icon -->
                                        <Setter Property="Data" Value="M16 8 0 0 5.5 8 0 16Z"/>
                                        <Setter Property="Fill" Value="#000"/>
                                        <Setter Property="Width" Value="14"/>
                                        <Setter Property="Height" Value="14"/>
                                        <Setter Property="Stretch" Value="Uniform"/>
                                        <Style.Triggers>
                                            <!-- Stop icon when streaming -->
                                            <DataTrigger Binding="{Binding IsStreaming}" Value="True">
                                                <Setter Property="Data" Value="M0 0H4V4H0Z"/>
                                                <Setter Property="Fill" Value="#D4D4D4"/>
                                                <Setter Property="Width" Value="12"/>
                                                <Setter Property="Height" Value="12"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Path.Style>
                            </Path>
                        </Button>
                    </Grid>

                    <!-- Bottom bar: Fix Python Error (left) + keyboard hint (right) -->
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="Fix Python Error"
                                Click="OnFixErrorClick"
                                Cursor="Hand"
                                Padding="8,4"
                                FontSize="11">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#2D2D2D"/>
                                    <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="4"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#3A3A3A"/>
                                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <TextBlock Grid.Column="1"
                                   Text="Enter to send  ·  Shift+Enter for new line"
                                   FontSize="10"
                                   Foreground="{StaticResource MutedBrush}"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"/>
                    </Grid>

                </StackPanel>
            </Border>

        </Grid>
        <!-- end chat panel -->

    </Grid>
</UserControl>
