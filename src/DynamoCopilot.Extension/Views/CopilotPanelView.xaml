<UserControl
    x:Class="DynamoCopilot.Extension.Views.CopilotPanelView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:DynamoCopilot.Extension.ViewModels"
    Background="#1E1E1E"
    Foreground="#D4D4D4"
    FontFamily="Segoe UI"
    FontSize="13"
    MinWidth="280">

    <UserControl.Resources>

        <!-- ── Colours ──────────────────────────────────────────────────── -->
        <SolidColorBrush x:Key="BgBrush"        Color="#1E1E1E"/>
        <SolidColorBrush x:Key="BgInputBrush"   Color="#2D2D2D"/>
        <SolidColorBrush x:Key="BgUserBrush"    Color="#2A3A52"/>
        <SolidColorBrush x:Key="BgAssistBrush"  Color="#252526"/>
        <SolidColorBrush x:Key="BgCodeBrush"    Color="#1A1A1A"/>
        <SolidColorBrush x:Key="AccentBrush"    Color="#6EC6F5"/>
        <SolidColorBrush x:Key="BorderBrush"    Color="#3A3A3A"/>
        <SolidColorBrush x:Key="TextBrush"      Color="#D4D4D4"/>
        <SolidColorBrush x:Key="MutedBrush"     Color="#8B8B8B"/>
        <SolidColorBrush x:Key="ErrorBrush"     Color="#F48771"/>

        <!-- ── Bool → Visibility ───────────────────────────────────────── -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- ── Inverse bool → Visibility ───────────────────────────────── -->
        <Style x:Key="InverseVisStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsStreaming}" Value="False">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- ── Scrollbar style (thin, dark) ─────────────────────────────── -->
        <Style x:Key="ThinScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#3A3A3A" CornerRadius="3" Margin="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThinScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter x:Name="PART_ScrollContentPresenter" Grid.Column="0" CanContentScroll="True"/>
                            <ScrollBar Grid.Column="1"
                                       Orientation="Vertical"
                                       Style="{StaticResource ThinScrollBar}"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── User message bubble ───────────────────────────────────────── -->
        <DataTemplate x:Key="UserMessageTemplate" DataType="{x:Type vm:ChatMessageViewModel}">
            <Grid Margin="8,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <!-- Role label -->
                <TextBlock Grid.Row="0" Text="You"
                           FontSize="10" Foreground="{StaticResource MutedBrush}"
                           FontWeight="SemiBold" Margin="0,0,0,3"
                           HorizontalAlignment="Right"/>
                <!-- Bubble -->
                <Border Grid.Row="1"
                        Background="{StaticResource BgUserBrush}"
                        CornerRadius="8,8,2,8"
                        Padding="10,8"
                        HorizontalAlignment="Right"
                        MaxWidth="320">
                    <TextBox Text="{Binding Content}"
                             Foreground="{StaticResource TextBrush}"
                             Background="Transparent"
                             BorderThickness="0"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             FontSize="13"
                             Padding="0"
                             Cursor="IBeam"/>
                </Border>
            </Grid>
        </DataTemplate>

        <!-- ── Assistant message bubble ─────────────────────────────────── -->
        <DataTemplate x:Key="AssistantMessageTemplate" DataType="{x:Type vm:ChatMessageViewModel}">
            <Grid Margin="8,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Role label -->
                <TextBlock Grid.Row="0" Text="DynamoCopilot"
                           FontSize="10" Foreground="{StaticResource AccentBrush}"
                           FontWeight="SemiBold" Margin="0,0,0,3"
                           HorizontalAlignment="Left"/>

                <!-- Prose bubble (hidden if empty) -->
                <Border Grid.Row="1"
                        Background="{StaticResource BgAssistBrush}"
                        CornerRadius="8,8,8,2"
                        Padding="10,8"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,8,0">
                    <StackPanel>
                        <!-- Text content -->
                        <TextBox Text="{Binding Content}"
                                 Foreground="{StaticResource TextBrush}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 FontSize="13"
                                 Padding="0"
                                 Cursor="IBeam"/>
                        <!-- Streaming indicator -->
                        <StackPanel Orientation="Horizontal"
                                    Visibility="{Binding IsStreaming, Converter={StaticResource BoolToVis}}">
                            <Ellipse Width="5" Height="5" Fill="{StaticResource AccentBrush}" Margin="2,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Style.Triggers>
                                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="1" To="0.2" Duration="0:0:0.6"
                                                                         AutoReverse="True"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <Ellipse Width="5" Height="5" Fill="{StaticResource AccentBrush}" Margin="2,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Style.Triggers>
                                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.2">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="1" To="0.2" Duration="0:0:0.6"
                                                                         AutoReverse="True"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <Ellipse Width="5" Height="5" Fill="{StaticResource AccentBrush}" Margin="2,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Style.Triggers>
                                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.4">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="1" To="0.2" Duration="0:0:0.6"
                                                                         AutoReverse="True"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Code block (shown only when code was extracted) -->
                <Border Grid.Row="2"
                        Background="{StaticResource BgCodeBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Margin="0,6,8,0"
                        Visibility="{Binding HasCode, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <!-- Code header bar -->
                        <Border Background="#2A2A2A" CornerRadius="6,6,0,0" Padding="10,5">
                            <Grid>
                                <TextBlock Text="python" Foreground="{StaticResource MutedBrush}"
                                           FontSize="11" FontFamily="Consolas"
                                           VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button x:Name="CopyBtn"
                                            Content="Copy"
                                            FontSize="11"
                                            Padding="8,3"
                                            Margin="0,0,4,0"
                                            Click="OnCopyCodeClick"
                                            Tag="{Binding CodeSnippet}"
                                            Cursor="Hand">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="#3A3A3A"/>
                                                <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}"
                                                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#4A4A4A"/>
                                                        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="Insert ↗"
                                            FontSize="11"
                                            FontWeight="SemiBold"
                                            Padding="8,3"
                                            Click="OnInsertCodeClick"
                                            Tag="{Binding CodeSnippet}"
                                            Cursor="Hand">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="#6EC6F5"/>
                                                <Setter Property="Foreground" Value="#000000"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}"
                                                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#9CD5F9"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <!-- Code text -->
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled"
                                      Padding="10,8">
                            <TextBlock Text="{Binding CodeSnippet}"
                                       FontFamily="Cascadia Code, Consolas, Courier New"
                                       FontSize="12"
                                       Foreground="#CE9178"
                                       TextWrapping="NoWrap"/>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

            </Grid>
        </DataTemplate>

        <!-- ── Message selector ──────────────────────────────────────────── -->
        <DataTemplate x:Key="MessageTemplate" DataType="{x:Type vm:ChatMessageViewModel}">
            <ContentControl>
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Setter Property="ContentTemplate" Value="{StaticResource AssistantMessageTemplate}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsUser}" Value="True">
                                <Setter Property="ContentTemplate" Value="{StaticResource UserMessageTemplate}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
                <ContentControl.Content>
                    <Binding/>
                </ContentControl.Content>
            </ContentControl>
        </DataTemplate>

    </UserControl.Resources>

    <!-- ── Layout ─────────────────────────────────────────────────────────── -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="*"/>      <!-- Chat area -->
            <RowDefinition Height="Auto"/>   <!-- Status bar -->
            <RowDefinition Height="Auto"/>   <!-- Input -->
        </Grid.RowDefinitions>

        <!-- ── Header ───────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="#252526"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Copilot icon (simple star/sparkle path) -->
                    <Path Data="M8,1 L9.2,5.5 L13.5,5.5 L10,8.5 L11.2,13 L8,10.5 L4.8,13 L6,8.5 L2.5,5.5 L6.8,5.5 Z"
                          Fill="#6EC6F5" Width="14" Height="14" Stretch="Uniform" Margin="0,0,7,0"/>
                    <TextBlock Text="DynamoCopilot"
                               Foreground="{StaticResource TextBrush}"
                               FontWeight="SemiBold"
                               FontSize="13"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <!-- Header buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">

                <!-- Settings button -->
                <Button ToolTip="Settings"
                        Click="OnSettingsClick"
                        Cursor="Hand"
                        Margin="0,0,4,0"
                        Padding="5">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#3A3A3A"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <!-- Gear icon -->
                    <Path Data="M9.405 1.05c-.413-1.4-2.397-1.4-2.81 0l-.1.34a1.464 1.464 0 0 1-2.105.872l-.31-.17c-1.283-.698-2.686.705-1.987 1.987l.169.311c.446.82.023 1.841-.872 2.105l-.34.1c-1.4.413-1.4 2.397 0 2.81l.34.1a1.464 1.464 0 0 1 .872 2.105l-.17.31c-.698 1.283.705 2.686 1.987 1.987l.311-.169a1.464 1.464 0 0 1 2.105.872l.1.34c.413 1.4 2.397 1.4 2.81 0l.1-.34a1.464 1.464 0 0 1 2.105-.872l.31.17c1.283.698 2.686-.705 1.987-1.987l-.169-.311a1.464 1.464 0 0 1 .872-2.105l.34-.1c1.4-.413 1.4-2.397 0-2.81l-.34-.1a1.464 1.464 0 0 1-.872-2.105l.17-.31c.698-1.283-.705-2.686-1.987-1.987l-.311.169a1.464 1.464 0 0 1-2.105-.872l-.1-.34zM8 10.93a2.929 2.929 0 1 1 0-5.86 2.929 2.929 0 0 1 0 5.858z"
                          Fill="{StaticResource MutedBrush}" Width="14" Height="14" Stretch="Uniform"/>
                </Button>

                <!-- Clear button -->
                <Button ToolTip="Clear conversation"
                        Click="OnClearClick"
                        Cursor="Hand"
                        Padding="5">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#3A3A3A"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Path Data="M6.5 1h3a.5.5 0 0 1 .5.5v1H6v-1a.5.5 0 0 1 .5-.5M11 2.5v-1A1.5 1.5 0 0 0 9.5 0h-3A1.5 1.5 0 0 0 5 1.5v1H1.5a.5.5 0 0 0 0 1H2v9a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2v-9h.5a.5.5 0 0 0 0-1H11Z"
                          Fill="{StaticResource MutedBrush}" Width="14" Height="14" Stretch="Uniform"/>
                </Button>

                </StackPanel>
            </Grid>
        </Border>
        <!-- ── Settings panel (Row 1, visible when ShowSettings=True) ─────────────── -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Background="#1E1E1E">
            <ScrollViewer.Style>
                <Style TargetType="ScrollViewer">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowSettings}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ScrollViewer.Style>
            <StackPanel Margin="14,12">

                <TextBlock Text="AI Provider" FontSize="14" FontWeight="SemiBold"
                           Foreground="#D4D4D4" Margin="0,0,0,12"/>

                <!-- Provider -->
                <TextBlock Text="Provider" FontSize="11" Foreground="#8B8B8B" Margin="0,0,0,4"/>
                <ComboBox SelectedIndex="{Binding SelectedProviderIndex, Mode=TwoWay}"
                          FontSize="12" Margin="0,0,0,8">
                    <ComboBox.Style>
                        <Style TargetType="ComboBox">
                            <Setter Property="Background" Value="#2D2D2D"/>
                            <Setter Property="Foreground" Value="#D4D4D4"/>
                            <Setter Property="BorderBrush" Value="#3A3A3A"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ComboBox">
                                        <Grid>
                                            <ToggleButton Background="{TemplateBinding Background}"
                                                          BorderBrush="{TemplateBinding BorderBrush}"
                                                          BorderThickness="{TemplateBinding BorderThickness}"
                                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                          Cursor="Hand">
                                                <ToggleButton.Template>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="3">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition/>
                                                                    <ColumnDefinition Width="20"/>
                                                                </Grid.ColumnDefinitions>
                                                                <ContentPresenter Grid.Column="0" Margin="6,4"/>
                                                                <Path Grid.Column="1" Data="M0,0 L4,4 L8,0"
                                                                      Stroke="#8B8B8B" StrokeThickness="1.5"
                                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Grid>
                                                        </Border>
                                                    </ControlTemplate>
                                                </ToggleButton.Template>
                                            </ToggleButton>
                                            <ContentPresenter Margin="6,4,24,4"
                                                              Content="{TemplateBinding SelectionBoxItem}"
                                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                              VerticalAlignment="Center"
                                                              TextElement.Foreground="#D4D4D4"/>
                                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False"
                                                   Placement="Bottom" PopupAnimation="Slide">
                                                <Border Background="#2D2D2D" BorderBrush="#3A3A3A" BorderThickness="1"
                                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                                        MinWidth="{TemplateBinding ActualWidth}">
                                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                        <ItemsPresenter/>
                                                    </ScrollViewer>
                                                </Border>
                                            </Popup>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ComboBox.Style>
                    <ComboBox.ItemContainerStyle>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="Foreground" Value="#D4D4D4"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Padding" Value="8,6"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ComboBoxItem">
                                        <Border Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter TextElement.Foreground="{TemplateBinding Foreground}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsHighlighted" Value="True">
                                    <Setter Property="Background" Value="#3E3E3E"/>
                                    <Setter Property="Foreground" Value="#6EC6F5"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#37373D"/>
                                    <Setter Property="Foreground" Value="#D4D4D4"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ComboBox.ItemContainerStyle>
                    <ComboBoxItem Content="Groq  (Free tier)"/>
                    <ComboBoxItem Content="Gemini  (Free tier)"/>
                    <ComboBoxItem Content="OpenRouter  (Free models available)"/>
                    <ComboBoxItem Content="Ollama  (Local, completely free)"/>
                    <ComboBoxItem Content="OpenAI  (Paid)"/>
                </ComboBox>

                <!-- Provider note -->
                <TextBlock Text="{Binding ProviderNote}" FontSize="11"
                           Foreground="#6EC6F5" TextWrapping="Wrap" Margin="0,0,0,12"/>

                <!-- API Key (hidden for Ollama) -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsOllama}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="{Binding ApiKeyLabel}" FontSize="11" Foreground="#8B8B8B" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding SettingsApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Background="#2D2D2D" Foreground="#D4D4D4" BorderBrush="#3A3A3A"
                             FontFamily="Consolas" FontSize="11" Padding="6,5" Margin="0,0,0,12"
                             BorderThickness="1"/>
                </StackPanel>

                <!-- Ollama endpoint (shown only for Ollama) -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsOllama}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Ollama Endpoint" FontSize="11" Foreground="#8B8B8B" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding SettingsEndpoint, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Background="#2D2D2D" Foreground="#D4D4D4" BorderBrush="#3A3A3A"
                             FontSize="12" Padding="6,5" Margin="0,0,0,12"
                             BorderThickness="1"/>
                </StackPanel>

                <!-- Model -->
                <TextBlock Text="Model" FontSize="11" Foreground="#8B8B8B" Margin="0,0,0,4"/>
                <TextBox Text="{Binding SettingsModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Background="#2D2D2D" Foreground="#D4D4D4" BorderBrush="#3A3A3A"
                         FontSize="12" Padding="6,5" Margin="0,0,0,4"
                         BorderThickness="1"/>
                <TextBlock Text="{Binding ModelHint}" FontSize="10" Foreground="#5A5A5A"
                           TextWrapping="Wrap" Margin="0,0,0,16"/>

                <!-- Save / Cancel -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Save" Click="OnSaveSettingsClick" Padding="0,8" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#6EC6F5"/>
                                <Setter Property="Foreground" Value="#000"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#9CD5F9"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Grid.Column="2" Content="Cancel" Click="OnCancelSettingsClick" Padding="0,8" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#3A3A3A"/>
                                <Setter Property="Foreground" Value="#D4D4D4"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#4A4A4A"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

            </StackPanel>
        </ScrollViewer>
        <!-- ── Chat scroll area ──────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1"
                      x:Name="ChatScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Style="{StaticResource ThinScrollViewer}"
                      Background="{StaticResource BgBrush}"
                      Padding="0,4">            <ScrollViewer.Visibility>
                <Binding Path="ShowChat" Converter="{StaticResource BoolToVis}"/>
            </ScrollViewer.Visibility>
            <Grid>
                <!-- Welcome state -->
                <StackPanel x:Name="WelcomePanel"
                            Margin="16,32,16,0"
                            HorizontalAlignment="Center"
                            Visibility="{Binding ShowWelcome, Converter={StaticResource BoolToVis}}">
                    <Path Data="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z"
                          Fill="#6EC6F5" Width="40" Height="40" Stretch="Uniform"
                          HorizontalAlignment="Center" Margin="0,0,0,12" Opacity="0.8"/>
                    <TextBlock Text="DynamoCopilot"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="Ask me to write Dynamo Python Script code using the Revit API."
                               FontSize="12" Foreground="{StaticResource MutedBrush}"
                               TextWrapping="Wrap" TextAlignment="Center"
                               MaxWidth="240" Margin="0,0,0,20"/>
                    <!-- Example prompts -->
                    <StackPanel>
                        <Button Content="Get all wall lengths in view" Tag="Get all walls in the current view and return their lengths"
                                Click="OnExampleClick" Margin="0,0,0,6" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#2D2D2D"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="Padding" Value="10,8"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#333"/>
                                            <Setter Property="BorderBrush" Value="#6EC6F5"/>
                                            <Setter Property="Foreground" Value="#6EC6F5"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="List levels by elevation" Tag="Get all Revit levels and sort them by elevation"
                                Click="OnExampleClick" Margin="0,0,0,6" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#2D2D2D"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="Padding" Value="10,8"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#333"/>
                                            <Setter Property="BorderBrush" Value="#6EC6F5"/>
                                            <Setter Property="Foreground" Value="#6EC6F5"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Rename sheets with a prefix" Tag="Rename all sheets by prefixing their number with a custom prefix from IN[0]"
                                Click="OnExampleClick" Margin="0,0,0,6" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#2D2D2D"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="Padding" Value="10,8"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#333"/>
                                            <Setter Property="BorderBrush" Value="#6EC6F5"/>
                                            <Setter Property="Foreground" Value="#6EC6F5"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Place family at points" Tag="Place a family instance at each point from IN[0] list using IN[1] as the family type"
                                Click="OnExampleClick" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#2D2D2D"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="Padding" Value="10,8"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#333"/>
                                            <Setter Property="BorderBrush" Value="#6EC6F5"/>
                                            <Setter Property="Foreground" Value="#6EC6F5"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </StackPanel>

                <!-- Message list -->
                <ItemsControl x:Name="MessageListControl"
                              ItemsSource="{Binding Messages}"
                              ItemTemplate="{StaticResource MessageTemplate}"
                              Background="Transparent">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </Grid>
        </ScrollViewer>

        <!-- ── Status bar ────────────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="Transparent"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,4"
                Visibility="{Binding HasStatus, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource MutedBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- ── Input area ─────────────────────────────────────────────────── -->
        <Border Grid.Row="3"
                Background="{StaticResource BgBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="8,8,8,6">
            <StackPanel>
                <Border Background="{StaticResource BgInputBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="8,6">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=InputBox, Path=IsFocused}" Value="True">
                                    <Setter Property="BorderBrush" Value="#6EC6F5"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="InputBox"
                                 Grid.Column="0"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{StaticResource TextBrush}"
                                 CaretBrush="{StaticResource AccentBrush}"
                                 FontSize="13"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="False"
                                 MaxHeight="120"
                                 VerticalScrollBarVisibility="Auto"
                                 PreviewKeyDown="OnInputKeyDown"
                                 IsEnabled="{Binding IsNotStreaming}">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <!-- Placeholder via adorner workaround via Tag -->
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                        <!-- Send / Stop button -->
                        <Button Grid.Column="1"
                                x:Name="SendButton"
                                Margin="6,0,0,0"
                                Padding="7,5"
                                Cursor="Hand"
                                Click="OnSendClick"
                                VerticalAlignment="Bottom">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#6EC6F5"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="5" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#9CD5F9"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.5"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <!-- Send arrow icon (when not streaming) -->
                            <Grid Width="14" Height="14">
                                <Path Data="M.5 1.163A1 1 0 0 1 1.97.28l12.868 6.837a1 1 0 0 1 0 1.766L1.969 15.72A1 1 0 0 1 .5 14.836V10.33a1 1 0 0 1 .816-.983L8.5 8 1.316 6.653A1 1 0 0 1 .5 5.67V1.163Z"
                                      Fill="#000000" Stretch="Uniform"
                                      Visibility="{Binding IsNotStreaming, Converter={StaticResource BoolToVis}}"/>
                                <Rectangle Fill="#000000" Width="8" Height="8" RadiusX="1" RadiusY="1"
                                           Visibility="{Binding IsStreaming, Converter={StaticResource BoolToVis}}"/>
                            </Grid>
                        </Button>
                    </Grid>
                </Border>
                <TextBlock Text="Enter to send  ·  Shift+Enter for new line"
                           FontSize="10" Foreground="{StaticResource MutedBrush}"
                           Margin="2,4,0,0"/>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>

