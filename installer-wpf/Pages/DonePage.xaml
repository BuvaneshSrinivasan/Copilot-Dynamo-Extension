<UserControl x:Class="DynamoCopilot.Installer.Pages.DonePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Triggers>
        <!-- Fade-in the whole page on load -->
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="Root"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1"
                                     Duration="0:0:0.5"/>
                    <DoubleAnimation Storyboard.TargetName="ContentStack"
                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                     From="18" To="0"
                                     Duration="0:0:0.5">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid x:Name="Root" Opacity="0">
        <!-- Left accent stripe -->
        <Border Width="4" HorizontalAlignment="Left">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#20D68A" Offset="0"/>
                    <GradientStop Color="#1AB87A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- Centred content -->
        <StackPanel x:Name="ContentStack"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Margin="0,-20,0,0">
            <StackPanel.RenderTransform>
                <TranslateTransform Y="18"/>
            </StackPanel.RenderTransform>

            <!-- ── Checkmark circle ── -->
            <Grid HorizontalAlignment="Center" Margin="0,0,0,28">
                <!-- Outer glow ring -->
                <Ellipse Width="88" Height="88" HorizontalAlignment="Center">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#0D2A1E" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.Effect>
                        <DropShadowEffect Color="#20D68A" BlurRadius="28"
                                          ShadowDepth="0" Opacity="0.45"/>
                    </Ellipse.Effect>
                </Ellipse>

                <!-- Filled circle -->
                <Ellipse Width="68" Height="68" HorizontalAlignment="Center"
                         VerticalAlignment="Center">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#25E896" Offset="0"/>
                            <GradientStop Color="#18C47A" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.Effect>
                        <DropShadowEffect Color="#20D68A" BlurRadius="16"
                                          ShadowDepth="0" Opacity="0.6"/>
                    </Ellipse.Effect>
                </Ellipse>

                <!-- Checkmark — Viewbox+Canvas guarantees it centers in the Grid -->
                <Viewbox Width="30" Height="30"
                         HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Canvas Width="30" Height="30">
                        <Path Data="M 4,15 L 12,23 L 26,8"
                              Stroke="White" StrokeThickness="3"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"/>
                    </Canvas>
                </Viewbox>
            </Grid>

            <!-- ── "All done!" heading ── -->
            <TextBlock Text="All done!"
                       Foreground="#E2E8F8"
                       FontFamily="Segoe UI Light"
                       FontSize="30"
                       FontWeight="Light"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#20D68A" BlurRadius="20"
                                      ShadowDepth="0" Opacity="0.12"/>
                </TextBlock.Effect>
            </TextBlock>

            <!-- ── "Happy Vibe Coding!" ── -->
            <TextBlock Text="Happy Vibe Coding! ✨"
                       Foreground="#20D68A"
                       FontFamily="Segoe UI"
                       FontSize="16"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#20D68A" BlurRadius="14"
                                      ShadowDepth="0" Opacity="0.5"/>
                </TextBlock.Effect>
            </TextBlock>

            <!-- ── Instruction ── -->
            <TextBlock Text="Restart Dynamo to start using DynamoCopilot."
                       Foreground="#374260"
                       FontFamily="Segoe UI"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,36"/>

            <!-- ── Close button ── -->
            <Button Content="Close"
                    Style="{StaticResource GhostBtn}"
                    HorizontalAlignment="Center"
                    Click="CloseBtn_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
