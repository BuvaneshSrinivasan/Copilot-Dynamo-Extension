<Window x:Class="DynamoCopilot.Installer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DynamoCopilot Setup"
        Width="620" Height="450"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <!-- Outer shadow border -->
    <Border CornerRadius="14" BorderThickness="1">
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1C2040" Offset="0"/>
                <GradientStop Color="#0D1030" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0.8,1">
                <GradientStop Color="#09091C" Offset="0"/>
                <GradientStop Color="#0B0C20" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="40" ShadowDepth="0" Opacity="0.75"/>
        </Border.Effect>

        <Grid ClipToBounds="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="42"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── Ambient glow decorations ── -->
            <!-- Top-right blue glow -->
            <Ellipse Grid.RowSpan="2"
                     Width="380" Height="380"
                     HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,-200,-180,0"
                     IsHitTestVisible="False" Opacity="0.045">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#4F8EF7" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
            <!-- Bottom-left purple glow -->
            <Ellipse Grid.RowSpan="2"
                     Width="320" Height="320"
                     HorizontalAlignment="Left" VerticalAlignment="Bottom"
                     Margin="-160,0,0,-160"
                     IsHitTestVisible="False" Opacity="0.04">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#6366F1" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- ── Title / drag bar ── -->
            <Grid Grid.Row="0"
                  MouseLeftButtonDown="DragBar_MouseLeftButtonDown"
                  Background="Transparent">
                <TextBlock Text="DynamoCopilot Setup"
                           Foreground="#2E3860"
                           FontFamily="Segoe UI" FontSize="11"
                           VerticalAlignment="Center" Margin="20,0"/>
                <Button Style="{StaticResource CloseBtn}"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Margin="0,0,10,0"
                        Click="CloseBtn_Click">✕</Button>
            </Grid>

            <!-- ── Page host ── -->
            <ContentControl x:Name="PageHost" Grid.Row="1" Focusable="False"/>
        </Grid>
    </Border>
</Window>
