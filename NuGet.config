<?xml version="1.0" encoding="utf-8"?>
<!--
  Local NuGet.config for DynamoCopilot.
  Overrides machine-level config: only use nuget.org (avoids inaccessible private feeds).
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
